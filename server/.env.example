# ── Cricket Oracle backend config ──────────────────────────────────────────
# Copy this file to ".env" and fill in real values to go live.

# Result data provider — OPTIONAL. If left unset, it's inferred from the keys
# below: FOOTBALLDATA_KEY → "footballdata", CRICAPI_KEY → "cricapi", else "mock".
# Only set this to force a specific provider. (Don't pin it to "mock" in prod, or
# real data stays off even with a key present.)
# PROVIDER=footballdata

# football-data.org API key (when PROVIDER=footballdata). Free tier covers the
# FIFA World Cup. Publish challenges with apiMatchId = the football-data match id.
FOOTBALLDATA_KEY=

# CricketData.org / cricapi.com API key (when PROVIDER=cricapi).
CRICAPI_KEY=

# Port the API listens on.
PORT=3001

# Secret required to call the admin endpoints (publish / force-resolve).
# Change this to a long random string in production.
ADMIN_TOKEN=dev-secret-change-me

# How often the scheduler checks for matches that need resolving (cron expr).
# Default: every 5 minutes.
RESOLVE_CRON=*/5 * * * *

# Which sport's challenge bank to serve: "cricket" (default) or "football".
# Run a football instance for the Goal Oracle app, e.g. SPORT=football PORT=3002.
SPORT=cricket

# How many matches the board shows in each section (upcoming / recent).
BOARD_SIZE=5

# Seed ("house") votes so polls don't start at 0. Each match auto-gets ~this many
# votes, split unevenly. Set 0 to disable; override per match via /api/admin/seed.
SEED_VOTES_BASE=100

# ── Accounts (email OTP + Google) ───────────────────────────────────────────
# Email provider for login codes: "mock" (default — prints/returns the code,
# no real email) or "resend". For real email set EMAIL_PROVIDER=resend, add a
# free key from resend.com, and a verified from-address.
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM=Goal Oracle <onboarding@resend.dev>

# Secret used to sign stateless session tokens. Use a long random string in prod.
AUTH_SECRET=dev-auth-secret-change-me

# Google Sign-In / One Tap. Leave blank for dev/mock mode (the front-end shows a
# "Continue with Google (demo)" button). To go live: create an OAuth 2.0 Client
# ID (Web) at https://console.cloud.google.com, add your origin to "Authorized
# JavaScript origins" (e.g. http://localhost:5174), then set it here AND in the
# front-end (localStorage go_google_client_id). Run `npm install` to pull the
# verification library.
GOOGLE_CLIENT_ID=
