# ── Cricket Oracle backend config ──────────────────────────────────────────
# Copy this file to ".env" and fill in real values to go live.

# Which cricket-data provider to use: "mock" (default, zero setup) or "cricapi".
PROVIDER=mock

# CricketData.org / cricapi.com API key (only needed when PROVIDER=cricapi).
# Get a free key at https://cricketdata.org
CRICAPI_KEY=

# Port the API listens on.
PORT=3001

# Secret required to call the admin endpoints (publish / force-resolve).
# Change this to a long random string in production.
ADMIN_TOKEN=dev-secret-change-me

# How often the scheduler checks for matches that need resolving (cron expr).
# Default: every 5 minutes.
RESOLVE_CRON=*/5 * * * *

# Which sport's challenge bank to serve: "cricket" (default) or "football".
# Run a football instance for the Goal Oracle app, e.g. SPORT=football PORT=3002.
SPORT=cricket

# ── Accounts (phone OTP login) ──────────────────────────────────────────────
# SMS provider: "mock" (default — prints/returns the code, no real SMS) or a
# real one you wire in src/auth.js (e.g. MSG91 / Twilio).
SMS_PROVIDER=mock

# Secret used to sign stateless session tokens. Use a long random string in prod.
AUTH_SECRET=dev-auth-secret-change-me

# Google Sign-In / One Tap. Leave blank for dev/mock mode (the front-end shows a
# "Continue with Google (demo)" button). To go live: create an OAuth 2.0 Client
# ID (Web) at https://console.cloud.google.com, add your origin to "Authorized
# JavaScript origins" (e.g. http://localhost:5174), then set it here AND in the
# front-end (localStorage go_google_client_id). Run `npm install` to pull the
# verification library.
GOOGLE_CLIENT_ID=
